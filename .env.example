# =============================================================================
# Maintain@Github - Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- App ---
APP_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
DEBUG=false

# --- Domain / Traefik ---
DOMAIN=yourdomain.example.com
TRAEFIK_EMAIL=admin@example.com
# Generate with: htpasswd -nb admin yourpassword
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...

# --- GitHub OAuth ---
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://${DOMAIN}/auth/github/callback

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=maintain_github
POSTGRES_USER=maintain
POSTGRES_PASSWORD=change-me-strong-password

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OpenRouter AI ---
OPENROUTER_API_KEY=

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434

# --- File Storage ---
REPOS_STORAGE_PATH=/app/repos
MAX_REPO_SIZE_MB=500

# --- Security ---
ALLOWED_ORIGINS=https://${DOMAIN}
RATE_LIMIT_PER_MINUTE=60
