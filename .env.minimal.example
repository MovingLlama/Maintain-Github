# =============================================================================
# Maintain@Github - Minimal Setup Environment
# For use with docker-compose.minimal.yml
#
# Copy to .env: cp .env.minimal.example .env
# =============================================================================

# --- App ---
APP_SECRET_KEY=change-me-to-random-32-chars
DEBUG=false

# --- Domain (for OAuth callback) ---
DOMAIN=localhost

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# For local dev: http://localhost:8000/auth/github/callback
# For cloudflare tunnel: https://yourdomain.com/auth/github/callback
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# --- External PostgreSQL ---
# Use host.docker.internal to reach PostgreSQL on your Docker host machine
# Or set to your remote PostgreSQL host/IP
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=maintain_github
POSTGRES_USER=maintain
POSTGRES_PASSWORD=your_postgres_password

# --- Redis (internal - do not change unless you use an external Redis) ---
REDIS_URL=redis://redis:6379/0

# --- External Ollama ---
# Use host.docker.internal to reach Ollama on your Docker host machine
# Or set to your remote Ollama host
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- OpenRouter (optional) ---
OPENROUTER_API_KEY=

# --- JWT ---
JWT_SECRET_KEY=change-me-jwt-secret-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Storage ---
REPOS_STORAGE_PATH=/app/repos

# --- CORS (set to your frontend URL) ---
# For Cloudflare Tunnel: https://yourdomain.com
# For local dev: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Optional: Custom ports for this minimal setup ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
